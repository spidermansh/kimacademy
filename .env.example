NODE_ENV=development
PORT=3021

# PostgreSQL connection string. Use sslmode=require for Neon/Render/Supabase cloud DBs.
DATABASE_URL="postgresql://user:password@localhost:5432/kimacademy?schema=public"

# Required in production. Use a long random value, at least 32 characters.
JWT_SECRET="change-me-to-a-long-random-secret"

# Comma-separated allowed browser origins. Leave empty only for local development.
CORS_ORIGIN="http://localhost:3025"

# --- Optional tuning (có giá trị mặc định hợp lý nếu bỏ trống) ---
# Giới hạn kích thước body JSON (chống DoS payload lớn).
JSON_BODY_LIMIT="5mb"
# Số request đăng nhập tối đa trong 15 phút / IP (chống brute-force).
LOGIN_RATE_LIMIT="10"
# Cấu hình PostgreSQL connection pool.
DB_POOL_MAX="10"
DB_POOL_IDLE_MS="30000"
DB_POOL_CONN_TIMEOUT_MS="10000"
