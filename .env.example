NODE_ENV=development
PORT=3021

# PostgreSQL connection string. Use sslmode=require for Neon/Render/Supabase cloud DBs.
DATABASE_URL="postgresql://user:password@localhost:5432/kimacademy?schema=public"

# Required in production. Use a long random value, at least 32 characters.
JWT_SECRET="change-me-to-a-long-random-secret"

# Comma-separated allowed browser origins. Leave empty only for local development.
CORS_ORIGIN="http://localhost:3025"
