{
  "name": "kim-academy-v3",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx run-dev.ts",
    "build": "vite build && esbuild src/api/server.ts --bundle --platform=node --outfile=dist/server.js --format=esm --packages=external",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run --fileParallelism=false",
    "test:reports": "vitest run tests/unit/reports.test.ts",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:demo": "tsx src/tools/seed-demo.ts",
    "generate:templates": "tsx scripts/generate-import-templates.ts",
    "import:dryrun": "tsx scripts/import-real-data.ts",
    "import:confirm": "tsx scripts/import-real-data.ts --confirm",
    "import:clear-confirm": "tsx scripts/import-real-data.ts --clear --confirm"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "node-cron": "^4.4.1",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.5"
  }
}
