    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { PaymentMethod, StudyType } from \'../types\';\nimport { CheckCircle2 } from \'lucide-react\';\n\ninterface TransactionFormProps {\n  onSubmit: (data: any) => void;\n}\n\nexport default function TransactionForm({ onSubmit }: TransactionFormProps) {\n  const [paymentDate, setPaymentDate] = useState(new Date().toISOString().split(\'T\')[0]);\n  const [studentName, setStudentName] = useState(\'\');\n  const [className, setClassName] = useState(\'\');\n  const [studyType, setStudyType] = useState<StudyType>(\'Tr\341\273\261c ti\341\272\277p\');\n  const [term, setTerm] = useState(\'\');\n  const [amount, setAmount] = useState(\'\');\n  const [paymentMethod, setPaymentMethod] = useState<PaymentMethod>(\'Chuy\341\273\203n kho\341\272\243n\');\n  const [senderName, setSenderName] = useState(\'\');\n  const [notes, setNotes] = useState(\'\');\n\n  const [showSuccess, setShowSuccess] = useState(false);\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!studentName || !amount) return;\n\n    onSubmit({\n      paymentDate,\n      studentName,\n      className,\n      studyType,\n      term,\n      amount: parseInt(amount, 10),\n      paymentMethod,\n      senderName: paymentMethod === \'Chuy\341\273\203n kho\341\272\243n\' ? senderName : \'\',\n      notes,\n    });\n\n    // Reset some fields but keep date and class for convenience\n    setStudentName(\'\');\n    setAmount(\'\');\n    setSenderName(\'\');\n    setNotes(\'\');\n    \n    setShowSuccess(true);\n    setTimeout(() => setShowSuccess(false), 3000);\n  };\n\n  return (\n    <div className=\"bg-white p-6 rounded-xl border border-gray-200 shadow-sm\">\n      <div className=\"flex justify-between items-center mb-6\">\n        <h2 className=\"text-lg font-semibold text-gray-900\">Nh\341\272\255p Kho\341\272\243n Thu M\341\273\233i</h2>\n        {showSuccess && (\n          <span className=\"flex items-center text-sm font-medium text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full\">\n            <CheckCircle2 className=\"w-4 h-4 mr-1\" />\n            \304\220\303\243 l\306\260u th\303\240nh c\303\264ng\n          </span>\n        )}\n      </div>\n\n      <form onSubmit={handleSubmit} className=\"space-y-4\">\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">Ng\303\240y thu</label>\n            <input\n              type=\"date\"\n              required\n              value={paymentDate}\n              onChange={(e) => setPaymentDate(e.target.value)}\n              className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">T\303\252n h\341\273\215c vi\303\252n</label>\n            <input\n              type=\"text\"\n              required\n              placeholder=\"VD: Nguy\341\273\205n V\304\203n A\"\n              value={studentName}\n              onChange={(e) => setStudentName(e.target.value)}\n              className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">L\341\273\233p h\341\273\215c</label>\n            <input\n              type=\"text\"\n              placeholder=\"VD: IELTS 6.5\"\n              value={className}\n              onChange={(e) => setClassName(e.target.value)}\n              className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">K\341\273\263 h\341\273\215c / Th\303\241ng</label>\n            <input\n              type=\"text\"\n              placeholder=\"VD: Th\303\241ng 10/2023\"\n              value={term}\n              onChange={(e) => setTerm(e.target.value)}\n              className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">Lo\341\272\241i h\303\254nh</label>\n            <select\n              value={studyType}\n              onChange={(e) => setStudyType(e.target.value as StudyType)}\n              className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-gray-700 bg-white\"\n            >\n              <option value=\"Tr\341\273\261c ti\341\272\277p\">H\341\273\215c tr\341\273\261c ti\341\272\277p (Offline)</option>\n              <option value=\"Online\">H\341\273\215c Online (GVNN)</option>\n            </select>\n          </div>\n\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">S\341\273\221 ti\341\273\201n (VN\304\220)</label>\n            <input\n              type=\"number\"\n              required\n              min=\"0\"\n              step=\"1000\"\n              placeholder=\"0\"\n              value={amount}\n              onChange={(e) => setAmount(e.target.value)}\n              className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all\"\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">H\303\254nh th\341\273\251c thanh to\303\241n</label>\n            <div className=\"flex gap-4 items-center h-[42px]\">\n              <label className=\"flex items-center cursor-pointer\">\n                <input\n                  type=\"radio\"\n                  name=\"paymentMethod\"\n                  value=\"Chuy\341\273\203n kho\341\272\243n\"\n                  checked={paymentMethod === \'Chuy\341\273\203n kho\341\272\243n\'}\n                  onChange={(e) => setPaymentMethod(e.target.value as PaymentMethod)}\n                  className=\"w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500\"\n                />\n                <span className=\"ml-2 text-sm text-gray-700\">Chuy\341\273\203n kho\341\272\243n</span>\n              </label>\n              <label className=\"flex items-center cursor-pointer\">\n                <input\n                  type=\"radio\"\n                  name=\"paymentMethod\"\n                  value=\"Ti\341\273\201n m\341\272\267t\"\n                  checked={paymentMethod === \'Ti\341\273\201n m\341\272\267t\'}\n                  onChange={(e) => setPaymentMethod(e.target.value as PaymentMethod)}\n                  className=\"w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500\"\n                />\n                <span className=\"ml-2 text-sm text-gray-700\">Ti\341\273\201n m\341\272\267t</span>\n              </label>\n            </div>\n          </div>\n\n          {paymentMethod === \'Chuy\341\273\203n kho\341\272\243n\' && (\n            <div>\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">Ng\306\260\341\273\235i chuy\341\273\203n kho\341\272\243n</label>\n              <input\n                type=\"text\"\n                placeholder=\"T\303\252n ng\306\260\341\273\235i CK (n\341\272\277u kh\303\241c t\303\252n HV)\"\n                value={senderName}\n                onChange={(e) => setSenderName(e.target.value)}\n                className=\"w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-5