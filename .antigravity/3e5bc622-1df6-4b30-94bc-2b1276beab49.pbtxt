  user_input {
    user_response: "Apply the \"Geometric Balance\" design theme to the app.\n[AIS_METADATA_SECTION_START]\nDesign name: Geometric Balance\nDesign instructions: Extract ONLY the styling (colors, fonts, spacing, borders, shadows, backgrounds, gradients) and layout patterns (flexbox/grid structure, component arrangement) from the Design HTML below. Do NOT replace or restructure the existing app\'s HTML elements \342\200\224 preserve all existing components, content, and functionality. Only modify CSS/styling and adjust layout containers as needed to match the theme\'s aesthetic.\nDesign HTML:                   <!doctype html>\\n                  <html style=\\\"height: 100%; margin: 0;\\\">\\n                    <head>\\n                      <meta charset=\\\"UTF-8\\\" />\\n                      <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\" />\\n                      <script src=\\\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\\\"></script>\\n                      <link href=\\\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200\\\" rel=\\\"stylesheet\\\" />\\n                      <style>\\n                        body { margin: 0; height: 100%; display: flex; flex-direction: column; overflow: hidden; }\\n                        /* Fallback classes in case Tailwind fails to load in sandbox */\\n                        .h-full { height: 100%; }\\n                        .w-full { width: 100%; }\\n                        .flex { display: flex; }\\n                        .flex-col { flex-direction: column; }\\n                        .flex-1 { flex: 1 1 0%; }\\n                      </style>\\n                    </head>\\n                    <body>\\n                      <div class=\\\"w-[1024px] h-[768px] bg-slate-50 flex flex-col font-sans overflow-hidden text-slate-800\\\">\\n  <!-- Header Section -->\\n  <header class=\\\"h-16 bg-indigo-900 text-white flex items-center justify-between px-8 border-b border-indigo-950 shadow-md\\\">\\n    <div class=\\\"flex items-center gap-3\\\">\\n      <div class=\\\"w-10 h-10 bg-white rounded-md flex items-center justify-center\\\">\\n        <span class=\\\"text-indigo-900 font-bold text-xl\\\">KA</span>\\n      </div>\\n      <div>\\n        <h1 class=\\\"text-lg font-bold leading-tight uppercase tracking-wider\\\">Kim Academy</h1>\\n        <p class=\\\"text-xs text-indigo-300\\\">H\341\273\207 th\341\273\221ng qu\341\272\243n l\303\275 h\341\273\215c ph\303\255 & Thu chi</p>\\n      </div>\\n    </div>\\n    <div class=\\\"flex items-center gap-6\\\">\\n      <div class=\\\"text-right\\\">\\n        <p class=\\\"text-sm font-medium\\\">Nguy\341\273\205n Minh Anh</p>\\n        <p class=\\\"text-[10px] text-indigo-300 uppercase tracking-tighter\\\">Nh\303\242n vi\303\252n t\303\240i v\341\273\245 \342\200\242 Ph\303\262ng 102</p>\\n      </div>\\n      <div class=\\\"w-10 h-10 rounded-full bg-indigo-700 border-2 border-indigo-400\\\"></div>\\n    </div>\\n  </header>\\n\\n  <!-- Main Content Area -->\\n  <main class=\\\"flex-1 grid grid-cols-12 gap-0 overflow-hidden\\\">\\n    \\n    <!-- Sidebar: Student & Course Search -->\\n    <section class=\\\"col-span-3 border-r border-slate-200 bg-white p-6 flex flex-col gap-6\\\">\\n      <div>\\n        <label class=\\\"text-[10px] font-bold text-slate-400 uppercase mb-2 block tracking-widest\\\">1. T\303\254m ki\341\272\277m h\341\273\215c vi\303\252n</label>\\n        <div class=\\\"relative\\\">\\n          <input type=\\\"text\\\" placeholder=\\\"M\303\243 HV ho\341\272\267c S\341\273\221 \304\221i\341\273\207n tho\341\272\241i...\\\" class=\\\"w-full pl-3 pr-10 py-2 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none text-sm\\\">\\n          <div class=\\\"absolute right-3 top-2.5 text-slate-400\\\">\\n            <svg class=\\\"w-4 h-4\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path d=\\\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\\\"></path></svg>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <div class=\\\"bg-slate-50 p-4 border border-slate-200 rounded-lg\\\">\\n        <p class=\\\"text-xs font-bold text-indigo-900 mb-1\\\">L\303\252 Ho\303\240ng Nam</p>\\n        <p class=\\\"text-[11px] text-slate-500 mb-2\\\">HV-2024-9981 \342\200\242 L\341\273\233p IELTS 6.5</p>\\n        <span class=\\\"px-2 py-0.5 bg-green-100 text-green-700 text-[10px] font-bold rounded uppercase\\\">\304\220ang theo h\341\273\215c</span>\\n      </div>\\n\\n      <hr class=\\\"border-slate-100\\\">\\n\\n      <div>\\n        <label class=\\\"text-[10px] font-bold text-slate-400 uppercase mb-2 block tracking-widest\\\">2. Ch\341\273\215n kh\303\263a h\341\273\215c/D\341\273\213ch v\341\273\245</label>\\n        <select class=\\\"w-full p-2 border border-slate-300 rounded text-sm bg-white\\\">\\n          <option>IELTS Foundation (3 Th\303\241ng)</option>\\n          <option>English for Kids - Level 2</option>\\n          <option selected>IELTS Intensive 6.5+</option>\\n        </select>\\n        <div class=\\\"mt-4 flex flex-col gap-2\\\">\\n          <div class=\\\"flex justify-between text-xs\\\">\\n            <span class=\\\"text-slate-500\\\">H\341\273\215c ph\303\255 g\341\273\221c:</span>\\n            <span class=\\\"font-semibold\\\">12,500,000\304\221</span>\\n          </div>\\n          <div class=\\\"flex justify-between text-xs\\\">\\n            <span class=\\\"text-slate-500\\\">Gi\303\241o tr\303\254nh:</span>\\n            <span class=\\\"font-semibold\\\">450,000\304\221</span>\\n          </div>\\n        </div>\\n      </div>\\n    </section>\\n\\n    <!-- Center: Payment Detail Calculation -->\\n    <section class=\\\"col-span-5 bg-slate-50 p-8 flex flex-col border-r border-slate-200\\\">\\n      <div class=\\\"bg-white rounded-xl shadow-sm border border-slate-200 p-6\\\">\\n        <h2 class=\\\"text-lg font-bold text-slate-800 mb-6 flex items-center gap-2\\\">\\n          <span class=\\\"w-2 h-6 bg-indigo-600 rounded-full\\\"></span>\\n          Chi ti\341\272\277t thu ti\341\273\201n\\n        </h2>\\n\\n        <div class=\\\"space-y-4\\\">\\n          <div class=\\\"grid grid-cols-2 gap-4\\\">\\n            <div>\\n              <label class=\\\"text-[10px] font-bold text-slate-400 uppercase block mb-1\\\">H\303\254nh th\341\273\251c thu</label>\\n              <div class=\\\"grid grid-cols-2 gap-2\\\">\\n                <button class=\\\"py-2 px-3 border border-indigo-600 bg-indigo-50 text-indigo-700 rounded text-xs font-bold\\\">Ti\341\273\201n m\341\272\267t</button>\\n                <button class=\\\"py-2 px-3 border border-slate-200 bg-white text-slate-600 rounded text-xs font-medium hover:border-slate-300\\\">Chuy\341\273\203n kho\341\272\243n</button>\\n              </div>\\n            </div>\\n            <div>\\n              <label class=\\\"text-[10px] font-bold text-slate-400 uppercase block mb-1\\\">M\303\243 khuy\341\272\277n m\303\243i</label>\\n              <input type=\\\"text\\\" value=\\\"KIM_WELCOME\\\" class=\\\"w-full px-3 py-2 border border-slate-300 rounded text-sm uppercase font-mono\\\">\\n            </div>\\n          </div>\\n\\n          <div class=\\\"pt-4 border-t border-slate-100 space-y-3\\\">\\n            <div class=\\\"flex justify-between items-center\\\">\\n              <span class=\\\"text-sm text-slate-600\\\">T\341\273\225ng c\341\273\231ng h\341\273\215c ph\303\255</span>\\n              <span class=\\\"text-sm font-semibold\\\">12,950,000\304\221</span>\\n            </div>\\n            <div class=\\\"flex justify-between items-center text-red-600\\\">\\n              <span class=\\\"text-sm italic\\\">Gi\341\272\243m gi\303\241 (10%)</span>\\n              <span class=\\\"text-sm font-semibold\\\">-1,295,000\304\221</span>\\n            </div>\\n            <div class=\\\"flex justify-between items-center\\\">\\n              <span class=\\\"text-sm text-slate-600\\\">Ph\303\255 \304\221\341\273\223ng ph\341\273\245c</span>\\n              <span class=\\\"text-sm font-semibold\\\">300,000\304\221</span>\\n            </div>\\n          </div>\\n\\n          <div class=\\\"mt-8 bg-indigo-900 rounded-lg p-5 text-white flex justify-between items-end\\\">\\n            <div>\\n              <p class=\\\"text-[10px] uppercase tracking-widest opacity-70 mb-1\\\">S\341\273\221 ti\341\273\201n th\341\273\261c thu</p>\\n              <p class=\\\"text-3xl font-black\\\">11,955,000\304\221</p>\\n            </div>\\n            <div class=\\\"text-right\\\">\\n              <p class=\\\"text-[10px] italic opacity-60\\\">\304\220\303\243 bao g\341\273\223m VAT</p>\\n            </div>\\n          </div>\\n\\n          <div class=\\\"mt-4\\\">\\n            <label class=\\\"text-[10px] font-bold text-slate-400 uppercase block mb-1\\\">Ghi ch\303\272 phi\341\272\277u thu</label>\\n            <textarea class=\\\"w-full h-20 p-3 border border-slate-200 rounded text-sm text-slate-600 resize-none\\\" placeholder=\\\"Nh\341\272\255p ghi ch\303\272 (v\303\255 d\341\273\245: Ng\306\260\341\273\235i n\341\273\231p thay, \306\260u \304\221\303\243i \304\221\341\272\267c bi\341\273\207t...)\\\">H\341\273\215c vi\303\252n n\341\273\231p ti\341\273\201n \304\221\341\273\243t 1 (50% kh\303\263a h\341\273\215c). H\341\272\241n ho\303\240n th\303\240nh c\303\262n l\341\272\241i: 15/11/2024.</textarea>\\n          </div>\\n        </div>\\n      </div>\\n    </section>\\n\\n    <!-- Right Side: Preview & History -->\\n    <section class=\\\"col-span-4 bg-white p-6 flex flex-col\\\">\\n      <div class=\\\"flex-1\\\">\\n        <div class=\\\"border-2 border-dashed border-slate-200 rounded-lg p-6 bg-slate-50 relative\\\">\\n          <div class=\\\"absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-white border border-slate-200 rounded-full text-[10px] font-bold text-slate-400 uppercase\\\">\\n            Xem tr\306\260\341\273\233c phi\341\272\277u thu\\n          </div>\\n          \\n          <div class=\\\"text-center mb-4\\\">\\n            <h3 class=\\\"text-xs font-bold uppercase\\\">Phi\341\272\277u thu h\341\273\215c ph\303\255</h3>\\n            <p class=\\\"text-[9px] text-slate-500 italic\\\">S\341\273\221: PT/2024/11/0822</p>\\n          </div>\\n\\n          <div class=\\\"space-y-2 border-t border-b border-slate-200 py-3 mb-4\\\">\\n            <div class=\\\"flex justify-between text-[11px]\\\"><span class=\\\"text-slate-500\\\">\304\220\306\241n v\341\273\213:</span><span class=\\\"font-medium\\\">Kim Academy</span></div>\\n            <div class=\\\"flex justify-between text-[11px]\\\"><span class=\\\"text-slate-500\\\">H\341\273\215 t\303\252n:</span><span class=\\\"font-medium\\\">L\303\252 Ho\303\240ng Nam</span></div>\\n            <div class=\\\"flex justify-between text-[11px]\\\"><span class=\\\"text-slate-500\\\">L\303\275 do:</span><span class=\\\"font-medium\\\">H\341\273\215c ph\303\255 IELTS Intensive</span></div>\\n            <div class=\\\"flex justify-between text-[11px]\\\"><span class=\\\"text-slate-500\\\">S\341\273\221 ti\341\273\201n:</span><span class=\\\"font-bold\\\">11,955,000\304\221</span></div>\\n          </div>\\n          \\n          <div class=\\\"grid grid-cols-2 gap-4 text-center text-[10px] text-slate-400\\\">\\n            <div>\\n              <p class=\\\"mb-10 font-bold uppercase\\\">Ng\306\260\341\273\235i n\341\273\231p</p>\\n              <p class=\\\"italic\\\">(K\303\275, ghi r\303\265 h\341\273\215 t\303\252n)</p>\\n            </div>\\n            <div>\\n              <p class=\\\"mb-10 font-bold uppercase\\\">Ng\306\260\341\273\235i thu</p>\\n              <p class=\\\"italic\\\">(K\303\275, ghi r\303\265 h\341\273\215 t\303\252n)</p>\\n            </div>\\n          </div>\\n        </div>\\n\\n        <div class=\\\"mt-8\\\">\\n          <h4 class=\\\"text-[11px] font-bold text-slate-800 uppercase mb-3 flex items-center gap-2\\\">\\n            <svg class=\\\"w-3 h-3 text-indigo-500\\\" fill=\\\"currentColor\\\" viewBox=\\\"0 0 20 20\\\"><path d=\\\"M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z\\\"></path></svg>\\n            L\341\273\213ch s\341\273\255 giao d\341\273\213ch g\341\272\247n \304\221\303\242y\\n          </h4>\\n          <div class=\\\"space-y-2\\\">\\n            <div class=\\\"flex justify-between items-center p-2 border-b border-slate-100\\\">\\n              <div>\\n                <p class=\\\"text-xs font-medium\\\">Tr\341\272\247n Qu\341\273\221c B\341\272\243o</p>\\n                <p class=\\\"text-[10px] text-slate-400\\\">08/11/2024 \342\200\242 14:20</p>\\n              </div>\\n              <span class=\\\"text-xs font-bold text-indigo-700\\\">8.200.000\304\221</span>\\n            </div>\\n            <div class=\\\"flex justify-between items-center p-2 border-b border-slate-100\\\">\\n              <div>\\n                <p class=\\\"text-xs font-medium\\\">Ph\341\272\241m Thu H\303\240</p>\\n                <p class=\\\"text-[10px] text-slate-400\\\">08/11/2024 \342\200\242 11:45</p>\\n              </div>\\n              <span class=\\\"text-xs font-bold text-indigo-700\\\">15.500.000\304\221</span>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n    </section>\\n  </main>\\n\\n  <!-- Footer Action Bar -->\\n  <footer class=\\\"h-16 bg-white border-t border-slate-200 flex items-center justify-between px-8\\\">\\n    <div class=\\\"flex gap-2 items-center text-slate-400\\\">\\n      <svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\\\"></path></svg>\\n      <p class=\\\"text-xs font-medium\\\">M\341\273\215i giao d\341\273\213ch s\341\272\275 \304\221\306\260\341\273\243c l\306\260u tr\341\273\257 t\341\273\261 \304\221\341\273\231ng v\303\240o b\303\241o c\303\241o t\303\240i ch\303\255nh th\303\241ng.</p>\\n    </div>\\n    <div class=\\\"flex gap-4\\\">\\n      <button class=\\\"px-6 py-2 bg-slate-100 text-slate-600 rounded font-bold text-sm hover:bg-slate-200\\\">H\341\273\247y b\341\273\217</button>\\n      <button class=\\\"px-8 py-2 bg-indigo-600 text-white rounded font-bold text-sm shadow-lg shadow-indigo-200 flex items-center gap-2 hover:bg-indigo-700\\\">\\n        <svg class=\\\"w-4 h-4\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z\\\"></path></svg>\\n        X\303\241c nh\341\272\255n & In phi\341\272\277u thu\\n      </button>\\n    </div>\\n  </footer>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
    items {
      text: "Apply the \"Geometric Balance\" design theme to the app.\n[AIS_METADATA_SECTION_START]\nDesign name: Geometric Balance\nDesign instructions: Extract ONLY the styling (colors, fonts, spacing, borders, shadows, backgrounds, gradients) and layout patterns (flexbox/grid structure, component arrangement) from the Design HTML below. Do NOT replace or restructure the existing app\'s HTML elements \342\200\224 preserve all existing components, content, and functionality. Only modify CSS/styling and adjust layout containers as needed to match the theme\'s aesthetic.\nDesign HTML:                   <!doctype html>\\n                  <html style=\\\"height: 100%; margin: 0;\\\">\\n                    <head>\\n                      <meta charset=\\\"UTF-8\\\" />\\n                      <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\" />\\n                      <script src=\\\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\\\"></script>\\n                      <link href=\\\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200\\\" rel=\\\"stylesheet\\\" />\\n                      <style>\\n                        body { margin: 0; height: 100%; display: flex; flex-direction: column; overflow: hidden; }\\n                        /* Fallback classes in case Tailwind fails to load in sandbox */\\n                        .h-full { height: 100%; }\\n                        .w-full { width: 100%; }\\n                        .flex { display: flex; }\\n                        .flex-col { flex-direction: column; }\\n                        .flex-1 { flex: 1 1 0%; }\\n                      </style>\\n                    </head>\\n                    <body>\\n                      <div class=\\\"w-[1024px] h-[768px] bg-slate-50 flex flex-col font-sans overflow-hidden text-slate-800\\\">\\n  <!-- Header Section -->\\n  <header class=\\\"h-16 bg-indigo-900 text-white flex items-center justify-between px-8 border-b border-indigo-950 shadow-md\\\">\\n    <div class=\\\"flex items-center gap-3\\\">\\n      <div class=\\\"w-10 h-10 bg-white rounded-md flex items-center justify-center\\\">\\n        <span class=\\\"text-indigo-900 font-bold text-xl\\\">KA</span>\\n      </div>\\n      <div>\\n        <h1 class=\\\"text-lg font-bold leading-tight uppercase tracking-wider\\\">Kim Academy</h1>\\n        <p class=\\\"text-xs text-indigo-300\\\">H\341\273\207 th\341\273\221ng qu\341\272\243n l\303\275 h\341\273\215c ph\303\255 & Thu chi</p>\\n      </div>\\n    </div>\\n    <div class=\\\"flex items-center gap-6\\\">\\n      <div class=\\\"text-right\\\">\\n        <p class=\\\"text-sm font-medium\\\">Nguy\341\273\205n Minh Anh</p>\\n        <p class=\\\"text-[10px] text-indigo-300 uppercase tracking-tighter\\\">Nh\303\242n vi\303\252n t\303\240i v\341\273\245 \342\200\242 Ph\303\262ng 102</p>\\n      </div>\\n      <div class=\\\"w-10 h-10 rounded-full bg-indigo-700 border-2 border-indigo-400\\\"></div>\\n    </div>\\n  </header>\\n\\n  <!-- Main Content Area -->\\n  <main class=\\\"flex-1 grid grid-cols-12 gap-0 overflow-hidden\\\">\\n    \\n    <!-- Sidebar: Student & Course Search -->\\n    <section class=\\\"col-span-3 border-r border-slate-200 bg-white p-6 flex flex-col gap-6\\\">\\n      <div>\\n        <label class=\\\"text-[10px] font-bold text-slate-400 uppercase mb-2 block tracking-widest\\\">1. T\303\254m ki\341\272\277m h\341\273\215c vi\303\252n</label>\\n        <div class=\\\"relative\\\">\\n          <input type=\\\"text\\\" placeholder=\\\"M\303\243 HV ho\341\272\267c S\341\273\221 \304\221i\341\273\207n tho\341\272\241i...\\\" class=\\\"w-full pl-3 pr-10 py-2 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none text-sm\\\">\\n          <div class=\\\"absolute right-3 top-2.5 text-slate-400\\\">\\n            <svg class=\\\"w-4 h-4\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path d=\\\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\\\"></path></svg>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <div class=\\\"bg-slate-50 p-4 border border-slate-200 rounded-lg\\\">\\n        <p class=\\\"text-xs font-bold text-indigo-900 mb-1\\\">L\303\252 Ho\303\240ng Nam</p>\\n        <p class=\\\"text-[11px] text-slate-500 mb-2\\\">HV-2024-9981 \342\200\242 L\341\273\233p IELTS 6.5</p>\\n        <span class=\\\"px-2 py-0.5 bg-green-100 text-green-700 text-[10px] font-bold rounded uppercase\\\">\304\220ang theo h\341\273\215c</span>\\n      </div>\\n\\n      <hr class=\\\"border-slate-100\\\">\\n\\n      <div>\\n        <label class=\\\"text-[10px] font-bold text-slate-400 uppercase mb-2 block tracking-widest\\\">2. Ch\341\273\215n kh\303\263a h\341\273\215c/D\341\273\213ch v\341\273\245</label>\\n        <select class=\\\"w-full p-2 border border-slate-300 rounded text-sm bg-white\\\">\\n          <option>IELTS Foundation (3 Th\303\241ng)</option>\\n          <option>English for Kids - Level 2</option>\\n          <option selected>IELTS Intensive 6.5+</option>\\n        </select>\\n        <div class=\\\"mt-4 flex flex-col gap-2\\\">\\n          <div class=\\\"flex justify-between text-xs\\\">\\n            <span class=\\\"text-slate-500\\\">H\341\273\215c ph\303\255 g\341\273\221c:</span>\\n            <span class=\\\"font-semibold\\\">12,500,000\304\221</span>\\n          </div>\\n          <div class=\\\"flex justify-between text-xs\\\">\\n            <span class=\\\"text-slate-500\\\">Gi\303\241o tr\303\254nh:</span>\\n            <span class=\\\"font-semibold\\\">450,000\304\221</span>\\n          </div>\\n        </div>\\n      </div>\\n    </section>\\n\\n    <!-- Center: Payment Detail Calculation -->\\n    <section class=\\\"col-span-5 bg-slate-50 p-8 flex flex-col border-r border-slate-200\\\">\\n      <div class=\\\"bg-white rounded-xl shadow-sm border border-slate-200 p-6\\\">\\n        <h2 class=\\\"text-lg font-bold text-slate-800 mb-6 flex items-center gap-2\\\">\\n          <span class=\\\"w-2 h-6 bg-indigo-600 rounded-full\\\"></span>\\n          Chi ti\341\272\277t thu ti\341\273\201n\\n        </h2>\\n\\n        <div class=\\\"space-y-4\\\">\\n          <div class=\\\"grid grid-cols-2 gap-4\\\">\\n            <div>\\n              <label class=\\\"text-[10px] font-bold text-slate-400 uppercase block mb-1\\\">H\303\254nh th\341\273\251c thu</label>\\n              <div class=\\\"grid grid-cols-2 gap-2\\\">\\n                <button class=\\\"py-2 px-3 border border-indigo-600 bg-indigo-50 text-indigo-700 rounded text-xs font-bold\\\">Ti\341\273\201n m\341\272\267t</button>\\n                <button class=\\\"py-2 px-3 border border-slate-200 bg-white text-slate-600 rounded text-xs font-medium hover:border-slate-300\\\">Chuy\341\273\203n kho\341\272\243n</button>\\n              </div>\\n            </div>\\n            <div>\\n              <label class=\\\"text-[10px] font-bold text-slate-400 uppercase block mb-1\\\">M\303\243 khuy\341\272\277n m\303\243i</label>\\n              <input type=\\\"text\\\" value=\\\"KIM_WELCOME\\\" class=\\\"w-full px-3 py-2 border border-slate-300 rounded text-sm uppercase font-mono\\\">\\n            </div>\\n          </div>\\n\\n          <div class=\\\"pt-4 border-t border-slate-100 space-y-3\\\">\\n            <div class=\\\"flex justify-between items-center\\\">\\n              <span class=\\\"text-sm text-slate-600\\\">T\341\273\225ng c\341\273\231ng h\341\273\215c ph\303\255</span>\\n              <span class=\\\"text-sm font-semibold\\\">12,950,000\304\221</span>\\n            </div>\\n            <div class=\\\"flex justify-between items-center text-red-600\\\">\\n              <span class=\\\"text-sm italic\\\">Gi\341\272\243m gi\303\241 (10%)</span>\\n              <span class=\\\"text-sm font-semibold\\\">-1,295,000\304\221</span>\\n            </div>\\n            <div class=\\\"flex justify-between items-center\\\">\\n            