    replacement_infos {
      original_chunk {
        target_content: "import { PieChart, Pie, Cell, Tooltip, Legend, ResponsiveContainer, BarChart, Bar, XAxis, YAxis, CartesianGrid } from \'recharts\';\n\ninterface ReportsDashboardProps {"
        replacement_content: "import { PieChart, Pie, Cell, Tooltip, Legend, ResponsiveContainer, BarChart, Bar, XAxis, YAxis, CartesianGrid } from \'recharts\';\nimport * as XLSX from \'xlsx\';\nimport { Download } from \'lucide-react\';\n\ninterface ReportsDashboardProps {"
      }
      num_matches: 1
    }
    replacement_infos {
      original_chunk {
        target_content: "  const [reportType, setReportType] = useState<\'day\' | \'month\'>(\'month\');\n  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split(\'T\')[0]);\n  const [selectedMonth, setSelectedMonth] = useState(new Date().toISOString().substring(0, 7)); // YYYY-MM\n\n  const filteredTransactions = useMemo(() => {\n    return transactions.filter(t => {\n      if (reportType === \'day\') {\n        return t.paymentDate === selectedDate;\n      } else {\n        return t.paymentDate.startsWith(selectedMonth);\n      }\n    });\n  }, [transactions, reportType, selectedDate, selectedMonth]);"
        replacement_content: "  const [reportType, setReportType] = useState<\'day\' | \'month\' | \'range\'>(\'month\');\n  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split(\'T\')[0]);\n  const [selectedMonth, setSelectedMonth] = useState(new Date().toISOString().substring(0, 7)); // YYYY-MM\n  const [startDate, setStartDate] = useState(new Date().toISOString().split(\'T\')[0]);\n  const [endDate, setEndDate] = useState(new Date().toISOString().split(\'T\')[0]);\n\n  const filteredTransactions = useMemo(() => {\n    return transactions.filter(t => {\n      if (reportType === \'day\') {\n        return t.paymentDate === selectedDate;\n      } else if (reportType === \'month\') {\n        return t.paymentDate.startsWith(selectedMonth);\n      } else {\n        return t.paymentDate >= startDate && t.paymentDate <= endDate;\n      }\n    });\n  }, [transactions, reportType, selectedDate, selectedMonth, startDate, endDate]);\n\n  const handleExportExcel = () => {\n    const dataToExport = filteredTransactions.sort((a, b) => a.paymentDate.localeCompare(b.paymentDate) || new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime()).map((t, index) => ({\n      \'STT\': index + 1,\n      \'NG\303\200Y THU\': t.paymentDate,\n      \'N\341\273\230I DUNG THU\': t.revenueCategory,\n      \'T\303\212N H\341\273\214C VI\303\212N\': t.studentName,\n      \'L\341\273\232P\': t.className,\n      \'S\341\273\220 TI\341\273\200N\': t.amount,\n      \'H\303\214NH TH\341\273\250C THU\': t.paymentMethod,\n      \'GHI CH\303\232\': t.notes || \'\'\n    }));\n\n    const worksheet = XLSX.utils.json_to_sheet(dataToExport);\n    \n    // Add some styling or column width to sheet if needed\n    const wscols = [\n      {wch: 5},  // STT\n      {wch: 15}, // NG\303\200Y THU\n      {wch: 20}, // N\341\273\230I DUNG THU\n      {wch: 25}, // T\303\212N H\341\273\214C VI\303\212N\n      {wch: 15}, // L\341\273\232P\n      {wch: 15}, // S\341\273\220 TI\341\273\200N\n      {wch: 20}, // H\303\214NH TH\341\273\250C THU\n      {wch: 30}  // GHI CH\303\232\n    ];\n    worksheet[\'!cols\'] = wscols;\n\n    const workbook = XLSX.utils.book_new();\n    XLSX.utils.book_append_sheet(workbook, worksheet, \'BaoCaoThu\');\n    \n    const fileName = reportType === \'day\' ? `BaoCaoThu_${selectedDate}.xlsx` \n                   : reportType === \'month\' ? `BaoCaoThu_${selectedMonth}.xlsx`\n                   : `BaoCaoThu_${startDate}_den_${endDate}.xlsx`;\n    \n    XLSX.writeFile(workbook, fileName);\n  };"
      }
      num_matches: 1
    }
    replacement_infos {
      original_chunk {
        target_content: "        <div className=\"flex items-center gap-4\">\n          <div className=\"flex bg-slate-100 p-1 rounded-lg\">\n            <button\n              onClick={() => setReportType(\'day\')}\n              className={`px-3 py-1.5 text-xs font-bold rounded-md transition-colors ${reportType === \'day\' ? \'bg-white text-indigo-700 shadow-sm\' : \'text-slate-500 hover:text-slate-700\'}`}\n            >\n              Theo ng\303\240y\n            </button>\n            <button\n              onClick={() => setReportType(\'month\')}\n              className={`px-3 py-1.5 text-xs font-bold rounded-md transition-colors ${reportType === \'month\' ? \'bg-white text-indigo-700 shadow-sm\' : \'text-slate-500 hover:text-slate-700\'}`}\n            >\n              Theo th\303\241ng\n            </button>\n          </div>\n          {reportType === \'day\' ? (\n             <input\n               type=\"date\"\n               value={selectedDate}\n               onChange={(e) => setSelectedDate(e.target.value)}\n               className=\"px-3 py-1.5 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm\"\n             />\n          ) : (\n             <input\n               type=\"month\"\n               value={selectedMonth}\n               onChange={(e) => setSelectedMonth(e.target.value)}\n               className=\"px-3 py-1.5 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm\"\n             />\n          )}\n        </div>"
        replacement_content: "        <div className=\"flex flex-col md:flex-row items-center gap-4 w-full sm:w-auto\">\n          <div className=\"flex bg-slate-100 p-1 rounded-lg self-start md:self-auto\">\n            <button\n              onClick={() => setReportType(\'day\')}\n              className={`px-3 py-1.5 text-xs font-bold rounded-md transition-colors whitespace-nowrap ${reportType === \'day\' ? \'bg-white text-indigo-700 shadow-sm\' : \'text-slate-500 hover:text-slate-700\'}`}\n            >\n              Theo ng\303\240y\n            </button>\n            <button\n              onClick={() => setReportType(\'month\')}\n              className={`px-3 py-1.5 text-xs font-bold rounded-md transition-colors whitespace-nowrap ${reportType === \'month\' ? \'bg-white text-indigo-700 shadow-sm\' : \'text-slate-500 hover:text-slate-700\'}`}\n            >\n              Theo th\303\241ng\n            </button>\n            <button\n              onClick={() => setReportType(\'range\')}\n              className={`px-3 py-1.5 text-xs font-bold rounded-md transition-colors whitespace-nowrap ${reportType === \'range\' ? \'bg-white text-indigo-700 shadow-sm\' : \'text-slate-500 hover:text-slate-700\'}`}\n            >\n              T\303\271y ch\341\273\215n\n            </button>\n          </div>\n          \n          <div className=\"flex items-center gap-2 self-start md:self-auto\">\n            {reportType === \'day\' ? (\n               <input\n                 type=\"date\"\n                 value={selectedDate}\n                 onChange={(e) => setSelectedDate(e.target.value)}\n                 className=\"px-3 py-1.5 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm\"\n               />\n            ) : reportType === \'month\' ? (\n               <input\n                 type=\"month\"\n                 value={selectedMonth}\n                 onChange={(e) => setSelectedMonth(e.target.value)}\n                 className=\"px-3 py-1.5 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm\"\n               />\n            ) : (\n                <div className=\"flex items-center gap-2\">\n                  <input\n                    type=\"date\"\n                    value={startDate}\n                    onChange={(e) => setStartDate(e.target.value)}\n                    className=\"px-3 py-1.5 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm w-[130px]\"\n                  />\n                  <span className=\"text-slate-400\">-</span>\n                  <input\n                    type=\"date\"\n                    value={endDate}\n                    onChange={(e) => setEndDate(e.target.value)}\n                    className=\"px-3 py-1.5 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm w-[130px]\"\n                  />\n                </div>\n            )}\n          </div>\n          \n          <button \n            onClick={handleExportExcel}\n            className=\"flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-1.5 rounded text-sm font-bold shadow-sm transition-colors whitespace-nowrap self-start md:self-auto ml-auto md:ml-0\"\n          >\n            <Download className=\"w-4 h-4\" />\n            Xu\341\272\245t Excel\n          </button>\n        </div>"
      }
      num_matches: 1
    }
  }
}
