  file_change {
    absolute_path_uri: "file:///src/components/TransactionTable.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Transaction } from \'../types\';\nimport { formatCurrency, formatDate } from \'../utils\';\nimport { Check, CheckCircle, Circle, FileText, Share, Receipt } from \'lucide-react\';\n\ninterface TransactionTableProps {\n  transactions: Transaction[];\n  onToggleReconciled: (id: string, currentStatus: boolean) => void;\n  onToggleInvoiced: (id: string, currentStatus: boolean) => void;\n  onDeleteTransaction: (id: string) => void;\n  onGenerateReport: () => void;\n}\n\nexport default function TransactionTable({\n  transactions,\n  onToggleReconciled,\n  onToggleInvoiced,\n  onDeleteTransaction,\n  onGenerateReport\n}: TransactionTableProps) {\n  const [filterDate, setFilterDate] = useState(new Date().toISOString().split(\'T\')[0]);\n  \n  const filteredTransactions = transactions\n    .filter(t => t.paymentDate === filterDate)\n    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\n\n  const totalAmount = filteredTransactions.reduce((sum, t) => sum + t.amount, 0);\n  const reconciledCount = filteredTransactions.filter(t => t.isReconciled).length;\n  const invoicedCount = filteredTransactions.filter(t => t.isInvoiced).length;\n\n  return (\n    <div className=\"bg-white p-6 rounded-xl border border-gray-200 shadow-sm flex flex-col h-full\">\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4\">\n        <div>\n          <h2 className=\"text-lg font-semibold text-gray-900\">S\341\273\225 Qu\341\273\271 & \304\220\341\273\221i Chi\341\272\277u</h2>\n          <p className=\"text-sm text-gray-500\">Qu\341\272\243n l\303\275 c\303\241c kho\341\272\243n thu v\303\240 tr\341\272\241ng th\303\241i</p>\n        </div>\n        \n        <div className=\"flex items-center gap-3 w-full sm:w-auto\">\n          <input\n            type=\"date\"\n            value={filterDate}\n            onChange={(e) => setFilterDate(e.target.value)}\n            className=\"px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm\"\n          />\n          <button\n            onClick={onGenerateReport}\n            className=\"flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap\"\n          >\n            <Share className=\"w-4 h-4\" />\n            B\303\241o c\303\241o K\341\272\277 to\303\241n\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-3 gap-4 mb-6\">\n        <div className=\"bg-blue-50 rounded-lg p-4 border border-blue-100\">\n          <p className=\"text-xs font-medium text-blue-600 uppercase tracking-wider mb-1\">T\341\273\225ng thu trong ng\303\240y</p>\n          <p className=\"text-2xl font-bold text-blue-900\">{formatCurrency(totalAmount)}</p>\n          <p className=\"text-xs text-blue-600 mt-1\">{filteredTransactions.length} giao d\341\273\213ch</p>\n        </div>\n        <div className=\"bg-emerald-50 rounded-lg p-4 border border-emerald-100\">\n          <p className=\"text-xs font-medium text-emerald-600 uppercase tracking-wider mb-1\">\304\220\303\243 \304\221\341\273\221i chi\341\272\277u (NVVP)</p>\n          <p className=\"text-2xl font-bold text-emerald-900\">{reconciledCount} / {filteredTransactions.length}</p>\n          <p className=\"text-xs text-emerald-600 mt-1\">B\306\260\341\273\233c 4</p>\n        </div>\n        <div className=\"bg-purple-50 rounded-lg p-4 border border-purple-100\">\n          <p className=\"text-xs font-medium text-purple-600 uppercase tracking-wider mb-1\">\304\220\303\243 xu\341\272\245t H\304\220 (K\341\272\277 to\303\241n)</p>\n          <p className=\"text-2xl font-bold text-purple-900\">{invoicedCount} / {filteredTransactions.length}</p>\n          <p className=\"text-xs text-purple-600 mt-1\">B\306\260\341\273\233c 6</p>\n        </div>\n      </div>\n\n      <div className=\"flex-1 overflow-auto rounded-lg border border-gray-200\">\n        <table className=\"min-w-full divide-y divide-gray-200\">\n          <thead className=\"bg-gray-50 sticky top-0 z-10\">\n            <tr>\n              <th scope=\"col\" className=\"px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">H\341\273\215c vi\303\252n / L\341\273\233p</th>\n              <th scope=\"col\" className=\"px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Chi ti\341\272\277t THU</th>\n              <th scope=\"col\" className=\"px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider\">S\341\273\221 ti\341\273\201n</th>\n              <th scope=\"col\" className=\"px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider\">NVVP \304\220\341\273\221i chi\341\272\277u</th>\n              <th scope=\"col\" className=\"px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider\">KT Xu\341\272\245t H\304\220</th>\n              <th scope=\"col\" className=\"px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider\"></th>\n            </tr>\n          </thead>\n          <tbody className=\"bg-white divide-y divide-gray-200\">\n            {filteredTransactions.length === 0 ? (\n              <tr>\n                <td colSpan={6} className=\"px-4 py-8 text-center text-gray-500 text-sm\">\n                  Kh\303\264ng c\303\263 kho\341\272\243n thu n\303\240o trong ng\303\240y n\303\240y.\n                </td>\n              </tr>\n            ) : (\n              filteredTransactions.map((t) => (\n                <tr key={t.id} className=\"hover:bg-gray-50 transition-colors\">\n                  <td className=\"px-4 py-3 whitespace-nowrap\">\n                    <div className=\"text-sm font-medium text-gray-900\">{t.studentName}</div>\n                    <div className=\"text-xs text-gray-500\">{t.className} \342\200\242 {t.studyType}</div>\n                  </td>\n                  <td className=\"px-4 py-3\">\n                    <div className=\"text-sm text-gray-900\">{t.paymentMethod}</div>\n                    <div className=\"text-xs text-gray-500 truncate max-w-[200px]\" title={t.notes || t.senderName}>\n                      {t.term && <span className=\"font-medium mr-1\">[{t.term}]</span>}\n                      {t.senderName && <span className=\"mr-1\">T\341\273\253: {t.senderName}</span>}\n                      {t.notes}\n                    </div>\n                  </td>\n                  <td className=\"px-4 py-3 whitespace-nowrap text-right text-sm font-medium text-gray-900\">\n                    {formatCurrency(t.amount)}\n                  </td>\n                  <td className=\"px-4 py-3 whitespace-nowrap text-center\">\n                    <button \n                      onClick={() => onToggleReconciled(t.id, t.isReconciled)}\n                      className={`inline-flex items-center justify-center w-8 h-8 rounded-full transition-colors ${\n                        t.isReconciled \n                          ? \'bg-emerald-100 text-emerald-600 hover:bg-emerald-200\' \n                          : \'bg-gray-100 text-gray-400 hover:bg-gray-200\'\n                      }`}\n                      title=\"NVVP X\303\241c nh\341\272\255n \304\221\341\273\221i chi\341\272\277u (B\306\260\341\273\233c 4)\"\n                    >\n                      {t.isReconciled ? <CheckCircle className=\"w-5 h-5\" /> : <Circle className=\"w-5 h-5\" />}\n                    </button>\n                  </td>\n                  <td className=\"px-4 py-3 whitespace-nowrap text-center\">\n                    <button \n                      onClick={() => onToggleInvoiced(t.id, t.isInvoiced)}\n                      className={`inline-flex items-center justify-center w-8 h-8 rounded-full transition-colors ${\n                        t.isInvoiced \n                          ? \'bg-purple-100 text-purple-600 hover:bg-purple-200\' \n                          : \'bg-gray-100 text-gray-400 hover:bg-gray-200\'\n                      }`}\n                      title=\"K\341\272\277 to\303\241n x\303\241c nh\341\272\255n \304\221\303\243 xu\341\272\245t h\303\263a \304\221\306\241n (B\306\260\341\273\233c 6)\"\n                    >\n                      {t.isInvoiced ? <Receipt className=\"w-5 h-5\" /> : <FileText className=\"w-5 h-5\" />}\n                    </button>\n                  </td>\n                  <td className=\"px-4 py-3 whitespace-nowrap text-right text-sm font-medium\">\n                    <button\n                      onClick={() => {\n                        if(window.confirm(\'B\341\272\241n c\303\263 ch\341\272\257c mu\341\273\221n x\303\263a kho\341\272\243n thu n\303\240y?\')) {\n                          onDeleteTransaction(t.id);\n                        }\n                      }}\n                      className=\"text-red-600 hover:text-red-900\"\n                    >\n                      X\303\263a\n                    </button>\n                  </td>\n                </tr>\n              ))\n            )}\n          </tbody>\n        </table>\n      </div>\n    </div>\n  );\n}\n"
    }
